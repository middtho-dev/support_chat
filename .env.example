# Required
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_GROUP_ID=-1001234567890
ADMIN_TOKEN=change-me-to-a-long-random-token

# App
PORT=3001
CORS_ORIGIN=*

# Optional persistent web push keys.
# If omitted, the app stores generated keys in the Docker data volume.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=support@example.com
